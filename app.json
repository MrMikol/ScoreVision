{
  "expo": {
    "name": "ScoreVision",
    "slug": "scorevision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f0e8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.michaeltan.scorevision"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f5f0e8"
      },
      "package": "com.michaeltan.scorevision"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "assets": [
      "./assets/correct.mp3",
      "./assets/wrong.mp3"
    ],
    "plugins": [
      "expo-audio"
    ]
  }
}
